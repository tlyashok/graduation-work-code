# ============================================================
# Итерация 2: все настройки стека
# Скопировать в .env и заполнить TMDB_API_KEY
# ============================================================

# --- БД ---
POSTGRES_DB=filmrec
POSTGRES_USER=filmrec
POSTGRES_PASSWORD=filmrec
DB_CPUS=4.0
DB_MEMORY=8G

# --- Рекомендательный сервис ---
DATABASE_URL=postgresql://filmrec:filmrec@db:5432/filmrec
REC_CPUS=1.0
REC_MEMORY=512M

# --- Пул соединений (итерация 1) ---
DB_POOL_MIN_SIZE=10          # размер пула одинаков для Python и Go (для чистоты сравнения)
DB_POOL_MAX_SIZE=10

# --- Кеш Redis (итерация 2) ---
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=60         # время жизни записи кеша, секунды (в эксперименте 60 и 600)
PORT_REDIS=6379

# --- Веб-система ---
RECOMMENDATION_SERVICE_URL=http://nginx:80

# --- TMDB ---
TMDB_API_KEY=                # вставить ключ с themoviedb.org (бесплатный)

# --- Инициализация данных ---
MOVIELENS_DATA_DIR=/data

# --- Алгоритм рекомендаций ---
SIMILARITY_K=30              # K ближайших соседей на фильм (офлайн-этап)
SIMILARITY_MIN_COMMON=5      # минимум общих пользователей для пары фильмов (офлайн-этап)
SIMILARITY_MIN_RATINGS=10    # минимум оценок у фильма для включения в модель (офлайн-этап)
REC_N_DEFAULT=10             # количество рекомендаций по умолчанию (онлайн-этап)
REC_MIN_RATINGS=5            # минимум оценок для персональных рекомендаций, иначе fallback (онлайн-этап)

# --- Порты ---
PORT_WEB=8088
PORT_REC=8000
PORT_NGINX=80
PORT_DB=5432
PORT_PROMETHEUS=9090
PORT_GRAFANA=3000
PORT_CADVISOR=8081
PORT_NODE_EXPORTER=9100
